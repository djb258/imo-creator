#!/bin/bash
# commit-msg hook for Barton Doctrine enforcement
# Validates commit messages include IMO phase and CTB layer references
# Install: cp .githooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Skip merge commits
if echo "$COMMIT_MSG" | grep -q "^Merge"; then
    exit 0
fi

# Skip revert commits
if echo "$COMMIT_MSG" | grep -q "^Revert"; then
    exit 0
fi

echo ""
echo "Validating commit message format..."

# Recommended format: [CTB-LAYER] Brief description
# Examples:
#   [system] Add auth middleware
#   [data] Fix Neon client connection pooling
#   [app] Implement scaffold workflow
#   [ai] Add Claude provider fallback
#   [ui] Update dashboard layout

# Check if message starts with a layer tag (optional but recommended)
if echo "$COMMIT_MSG" | grep -Eq "^\[(system|data|app|ai|ui|docs|config|test)\]"; then
    echo -e "${GREEN}OK${NC}: CTB layer tag present"
else
    echo -e "${YELLOW}SUGGESTION${NC}: Consider prefixing with CTB layer tag"
    echo "  Format: [layer] description"
    echo "  Layers: system, data, app, ai, ui, docs, config, test"
    echo ""
    # Not blocking, just suggesting
fi

# Check minimum length
if [ ${#COMMIT_MSG} -lt 10 ]; then
    echo -e "${RED}ERROR${NC}: Commit message too short (min 10 chars)"
    exit 1
fi

# Check for WIP commits on main branch (warn only)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    if echo "$COMMIT_MSG" | grep -iq "^wip\|work in progress"; then
        echo -e "${YELLOW}WARNING${NC}: WIP commit on $BRANCH branch"
    fi
fi

echo -e "${GREEN}Commit message validated${NC}"
exit 0
