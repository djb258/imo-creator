{
  "model": "IMO-Radial Architecture",
  "version": "1.1",
  "description": "IMO-Creator ecosystem hub-and-spoke architecture with Composio integration gateway and Master Failure Hub.",

  "centralHub": {
    "name": "IMO_CREATOR",
    "type": "root",
    "description": "AI-powered interface creation platform. Central axle of the wheel connecting all integration hubs.",
    "metric": {
      "name": "SYSTEM_HEALTH",
      "description": "Aggregated health score across all integration hubs, services, and failure states.",
      "formula": "weighted_average(hub_status * hub_weight) - (failure_penalty * active_failures)",
      "thresholds": {
        "healthy": ">= 0.9",
        "degraded": ">= 0.7",
        "critical": "< 0.7"
      }
    },
