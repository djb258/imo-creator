{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "work_packet.schema.json",
  "title": "WORK_PACKET",
  "description": "Governance envelope for planned work. Envelope is locked. Payload is open.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "change_type",
    "architectural_flag",
    "requires_pressure_test",
    "allowed_paths",
    "summary",
    "doctrine_version",
    "timestamp",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "type": "string",
      "enum": ["feature", "architectural", "refactor", "fix"]
    },
    "architectural_flag": {
      "type": "boolean"
    },
    "requires_pressure_test": {
      "type": "boolean",
      "description": "If true, Builder must produce ARCH_PRESSURE_REPORT.json and FLOW_PRESSURE_REPORT.json. Must be true when architectural_flag is true."
    },
    "flow_contract": {
      "type": "object",
      "description": "Required when structural objects or event flows change. Declares the IMO contract for the change.",
      "additionalProperties": false,
      "required": ["ingress", "middle", "egress"],
      "properties": {
        "ingress": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Ingress surface identifiers affected by this change."
        },
        "middle": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Middle layer transformation identifiers affected by this change."
        },
        "egress": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Egress surface identifiers affected by this change."
        }
      }
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "doctrine_version": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "if": {
    "properties": {
      "architectural_flag": { "const": true }
    }
  },
  "then": {
    "properties": {
      "requires_pressure_test": { "const": true }
    }
  }
}
