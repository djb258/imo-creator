{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workbench Configuration Schema",
  "description": "Schema for Workbench Backblaze B2 + DuckDB configuration",
  "type": "object",
  "properties": {
    "workbench": {
      "type": "object",
      "description": "Workbench module configuration",
      "required": ["enabled", "backblaze_b2"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable Workbench module",
          "default": true
        },
        "module_path": {
          "type": "string",
          "description": "Path to Workbench module",
          "default": "workbench"
        },
        "duckdb_path": {
          "type": "string",
          "description": "Path to DuckDB file",
          "default": "workbench/workbench.duckdb"
        },
        "backblaze_b2": {
          "type": "object",
          "description": "Backblaze B2 configuration",
          "required": ["api_version", "api_type"],
          "properties": {
            "api_version": {
              "type": "string",
              "description": "B2 API version",
              "enum": ["v2"],
              "default": "v2"
            },
            "api_type": {
              "type": "string",
              "description": "API type (native or s3)",
              "enum": ["native", "s3"],
              "default": "native"
            },
            "auth_endpoint": {
              "type": "string",
              "description": "B2 authorization endpoint",
              "format": "uri",
              "default": "https://api.backblazeb2.com/b2api/v2/b2_authorize_account"
            },
            "supports_master_key": {
              "type": "boolean",
              "description": "Whether the API supports Master Application Keys",
              "default": true
            },
            "documentation_url": {
              "type": "string",
              "description": "Link to B2 documentation",
              "format": "uri"
            },
            "setup_instructions": {
              "type": "string",
              "description": "Step-by-step setup instructions"
            },
            "required_permissions": {
              "type": "array",
              "description": "Required B2 permissions",
              "items": {
                "type": "string",
                "enum": [
                  "listBuckets",
                  "listFiles",
                  "readFiles",
                  "writeFiles",
                  "deleteFiles"
                ]
              },
              "default": [
                "listBuckets",
                "listFiles",
                "readFiles",
                "writeFiles"
              ]
            },
            "test_connection": {
              "type": "string",
              "description": "Command to test B2 connection",
              "default": "python workbench/bootstrap.py"
            },
            "common_issues": {
              "type": "array",
              "description": "Common troubleshooting issues",
              "items": {
                "type": "object",
                "properties": {
                  "issue": {
                    "type": "string",
                    "description": "Description of the issue"
                  },
                  "solution": {
                    "type": "string",
                    "description": "Solution to the issue"
                  }
                },
                "required": ["issue", "solution"]
              }
            }
          }
        },
        "required_env_vars": {
          "type": "array",
          "description": "Required environment variables",
          "items": {
            "type": "string"
          },
          "default": [
            "B2_KEY_ID",
            "B2_APPLICATION_KEY",
            "B2_BUCKET"
          ]
        },
        "optional_env_vars": {
          "type": "array",
          "description": "Optional environment variables",
          "items": {
            "type": "string"
          },
          "default": [
            "POSTGRES_URL",
            "VALIDATOR_ENDPOINT"
          ]
        },
        "inheritance": {
          "type": "object",
          "description": "Configuration for child repository inheritance",
          "properties": {
            "auto_copy_files": {
              "type": "array",
              "description": "Files/directories to auto-copy to child repos",
              "items": {
                "type": "string"
              },
              "default": ["workbench/", ".env.template"]
            },
            "auto_update_dependencies": {
              "type": "boolean",
              "description": "Auto-update dependencies in child repos",
              "default": true
            },
            "required_packages": {
              "type": "array",
              "description": "Required Python packages",
              "items": {
                "type": "string"
              },
              "default": [
                "python-dotenv",
                "requests",
                "duckdb"
              ]
            }
          }
        },
        "file_structure": {
          "type": "object",
          "description": "Workbench file structure",
          "properties": {
            "b2_client": {
              "type": "string",
              "description": "B2 client module path",
              "default": "workbench/b2_client.py"
            },
            "load_duckdb": {
              "type": "string",
              "description": "Load DuckDB module path",
              "default": "workbench/load_duckdb.py"
            },
            "save_duckdb": {
              "type": "string",
              "description": "Save DuckDB module path",
              "default": "workbench/save_duckdb.py"
            },
            "neon_pull": {
              "type": "string",
              "description": "Neon pull module path",
              "default": "workbench/neon_pull.py"
            },
            "run_diff": {
              "type": "string",
              "description": "Diff engine module path",
              "default": "workbench/run_diff.py"
            },
            "apply_deltas": {
              "type": "string",
              "description": "Apply deltas module path",
              "default": "workbench/apply_deltas.py"
            },
            "bootstrap": {
              "type": "string",
              "description": "Bootstrap script path",
              "default": "workbench/bootstrap.py"
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "workbench": {
        "enabled": true,
        "module_path": "workbench",
        "duckdb_path": "workbench/workbench.duckdb",
        "backblaze_b2": {
          "api_version": "v2",
          "api_type": "native",
          "auth_endpoint": "https://api.backblazeb2.com/b2api/v2/b2_authorize_account",
          "supports_master_key": true,
          "required_permissions": [
            "listBuckets",
            "listFiles",
            "readFiles",
            "writeFiles"
          ]
        },
        "required_env_vars": [
          "B2_KEY_ID",
          "B2_APPLICATION_KEY",
          "B2_BUCKET"
        ],
        "inheritance": {
          "auto_copy_files": [
            "workbench/",
            ".env.template"
          ],
          "auto_update_dependencies": true,
          "required_packages": [
            "python-dotenv",
            "requests",
            "duckdb"
          ]
        }
      }
    }
  ]
}
