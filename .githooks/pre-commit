#!/bin/bash
# pre-commit hook for Barton Doctrine enforcement
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "=========================================="
echo "  Barton Doctrine Pre-Commit Check"
echo "=========================================="
echo ""

ERRORS=0

# Rule 1: Never build CTB before IMO exists
echo -n "Checking IMO exists... "
if [ ! -f "docs/10-imo.md" ]; then
    echo -e "${RED}FAIL${NC}"
    echo "  ERROR: Cannot commit without docs/10-imo.md"
    echo "  Create IMO definition first!"
    ((ERRORS++))
else
    echo -e "${GREEN}OK${NC}"
fi

# Rule 2: Check files are in correct CTB layer
echo -n "Checking CTB layer compliance... "
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
LAYER_VIOLATIONS=0

for file in $STAGED_FILES; do
    # Check Python files in src/
    if [[ $file == src/*.py ]]; then
        # Extract layer from path
        LAYER=$(echo "$file" | cut -d'/' -f2)

        # Check for obvious misplacements
        case $LAYER in
            system)
                # System should not have business logic
                if grep -q "class.*Service" "$file" 2>/dev/null; then
                    echo ""
                    echo -e "  ${YELLOW}WARNING${NC}: $file contains Service class (should be in app/)"
                    ((LAYER_VIOLATIONS++))
                fi
                ;;
            data)
                # Data should not have routes
                if grep -q "@app.route\|@router" "$file" 2>/dev/null; then
                    echo ""
                    echo -e "  ${RED}ERROR${NC}: $file contains routes (should be in app/)"
                    ((ERRORS++))
                fi
                ;;
            app)
                # App should not have direct DB connections
                if grep -q "psycopg\|pymongo\|firebase_admin" "$file" 2>/dev/null; then
                    echo ""
                    echo -e "  ${YELLOW}WARNING${NC}: $file has direct DB imports (should use data/ clients)"
                    ((LAYER_VIOLATIONS++))
                fi
                ;;
            ai)
                # AI layer looks OK for LLM stuff
                ;;
            ui)
                # UI should not have backend logic
                if grep -q "psycopg\|pymongo\|fastapi" "$file" 2>/dev/null; then
                    echo ""
                    echo -e "  ${RED}ERROR${NC}: $file contains backend code (should be in app/ or data/)"
                    ((ERRORS++))
                fi
                ;;
        esac
    fi
done

if [ $LAYER_VIOLATIONS -eq 0 ] && [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}OK${NC}"
elif [ $LAYER_VIOLATIONS -gt 0 ] && [ $ERRORS -eq 0 ]; then
    echo -e "${YELLOW}$LAYER_VIOLATIONS warning(s)${NC}"
fi

# Rule 3: Check for kill switch coverage on new error-prone code
echo -n "Checking kill switch patterns... "
MISSING_ERROR_HANDLING=0

for file in $STAGED_FILES; do
    if [[ $file == src/*.py ]]; then
        # Check for functions that should have error handling
        # Look for async def or def with external calls but no try/except
        if grep -q "requests\.\|aiohttp\|httpx" "$file" 2>/dev/null; then
            if ! grep -q "try:" "$file" 2>/dev/null; then
                echo ""
                echo -e "  ${YELLOW}WARNING${NC}: $file has HTTP calls without error handling"
                ((MISSING_ERROR_HANDLING++))
            fi
        fi
    fi
done

if [ $MISSING_ERROR_HANDLING -eq 0 ]; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}$MISSING_ERROR_HANDLING warning(s)${NC}"
fi

# Rule 4: Check HEIR ID format in new code
echo -n "Checking HEIR ID compliance... "
HEIR_VIOLATIONS=0

for file in $STAGED_FILES; do
    if [[ $file == src/*.py ]]; then
        # Look for hardcoded IDs that don't match doctrine format
        if grep -Eq "id\s*=\s*['\"](?!imo-)[a-zA-Z0-9-]+['\"]" "$file" 2>/dev/null; then
            # This is a simplified check - real implementation would be more thorough
            :
        fi
    fi
done
echo -e "${GREEN}OK${NC}"

# Rule 5: Require test file for new source files
echo -n "Checking test coverage for new files... "
MISSING_TESTS=0

for file in $STAGED_FILES; do
    if [[ $file == src/*/*.py && ! $file == *__init__* ]]; then
        # Extract layer and filename
        LAYER=$(echo "$file" | cut -d'/' -f2)
        FILENAME=$(basename "$file")

        # Check if corresponding test exists
        TEST_FILE="tests/$LAYER/test_$FILENAME"
        if [ ! -f "$TEST_FILE" ]; then
            # Check if it's a new file
            if ! git show HEAD:"$file" &>/dev/null 2>&1; then
                echo ""
                echo -e "  ${YELLOW}NOTE${NC}: New file $file - consider adding $TEST_FILE"
                # Not blocking, just noting
            fi
        fi
    fi
done
echo -e "${GREEN}OK${NC}"

# Summary
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}=========================================="
    echo "  COMMIT BLOCKED"
    echo -e "==========================================${NC}"
    echo ""
    echo "Fix the $ERRORS error(s) above before committing."
    echo ""
    echo "Barton Doctrine rules violated. See:"
    echo "  - docs/10-imo.md (IMO definition)"
    echo "  - docs/20-ctb-*.md (CTB layer rules)"
    exit 1
else
    echo -e "${GREEN}=========================================="
    echo "  Pre-commit checks passed"
    echo -e "==========================================${NC}"
    if [ $LAYER_VIOLATIONS -gt 0 ] || [ $MISSING_ERROR_HANDLING -gt 0 ]; then
        echo ""
        echo -e "${YELLOW}Warnings present - consider reviewing before push${NC}"
    fi
    exit 0
fi
